// Avenir Souriant — Database Schema
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ──────────────────────────────────────────────

enum UserRole {
  ADMIN
  COMMITTEE
  INSTRUCTOR
}

enum ProjectType {
  WORKSHOP
  COURSE
  ACTIVITY
}

enum ProjectStatus {
  DRAFT
  SUBMITTED
  UNDER_REVIEW
  APPROVED
  REJECTED
  ACTIVE
  COMPLETED
  ARCHIVED
}

enum StaffRole {
  LEAD
  CO_INSTRUCTOR
  HELPER
}

enum EnrollmentStatus {
  CONFIRMED
  WAITLIST
  CANCELLED
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
  EXCUSED
}

enum ReviewActionType {
  APPROVE
  REJECT
  REQUEST_REVISION
}

enum MessageTag {
  QUESTION
  FEEDBACK
  DECISION
  ACTION_ITEM
}

// ─── Models ─────────────────────────────────────────────

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String
  role         UserRole @default(INSTRUCTOR)
  phone        String?
  availability String?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relations
  createdProjects Project[]
  projectStaff    ProjectStaff[]
  reviewActions   ReviewAction[]
  discussions     Discussion[]
  messages        Message[]
  notifications   Notification[]
}

model Project {
  id                String        @id @default(cuid())
  title             String
  description       String?
  type              ProjectType
  targetAgeGroup    String?
  language          String        @default("Arabe")
  status            ProjectStatus @default(DRAFT)

  // Schedule
  startDate            DateTime?
  endDate              DateTime?
  roomId               String?
  room                 Room?       @relation(fields: [roomId], references: [id])
  sessionPatternsJson  String?     // JSON: [{days:[1,3],startTime:"16:00",endTime:"17:30"}]

  // Budget
  registrationFee   Float?        @default(0)
  projectedCosts    Float?        @default(0)
  revenueEstimate   Float?        @default(0)
  actualCosts       Float?        @default(0)
  actualRevenue     Float?        @default(0)

  // Marketing
  publicDescription String?
  promoNotes        String?
  enrollmentOpen    DateTime?
  enrollmentClose   DateTime?
  maxCapacity       Int?          @default(20)

  // Tracking
  createdById       String
  createdBy         User          @relation(fields: [createdById], references: [id])
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  // Relations
  staff             ProjectStaff[]
  sessions          Session[]
  enrollments       Enrollment[]
  reviewActions     ReviewAction[]
  discussions       Discussion[]
}

model ProjectStaff {
  id        String   @id @default(cuid())
  projectId String
  userId    String
  role      StaffRole

  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id])

  @@unique([projectId, userId])
}

model Room {
  id       String    @id @default(cuid())
  name     String
  capacity Int       @default(20)
  color    String    @default("#3b82f6")

  sessions Session[]
  projects Project[]
}

model Session {
  id          String   @id @default(cuid())
  projectId   String
  roomId      String
  startTime   DateTime
  endTime     DateTime
  isCancelled Boolean  @default(false)
  notes       String?

  project     Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  room        Room       @relation(fields: [roomId], references: [id])
  attendance  Attendance[]

  @@index([roomId, startTime, endTime])
}

model Student {
  id          String   @id @default(cuid())
  firstName   String
  lastName    String
  dateOfBirth DateTime?
  parentName  String?
  parentEmail String?
  parentPhone String?
  notes       String?
  flags       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  enrollments Enrollment[]
  attendance  Attendance[]
}

model Enrollment {
  id         String           @id @default(cuid())
  studentId  String
  projectId  String
  status     EnrollmentStatus @default(CONFIRMED)
  enrolledAt DateTime         @default(now())

  student    Student          @relation(fields: [studentId], references: [id])
  project    Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([studentId, projectId])
}

model Attendance {
  id        String           @id @default(cuid())
  studentId String
  sessionId String
  status    AttendanceStatus @default(PRESENT)

  student   Student          @relation(fields: [studentId], references: [id])
  session   Session          @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@unique([studentId, sessionId])
}

model ReviewAction {
  id         String           @id @default(cuid())
  projectId  String
  reviewerId String
  action     ReviewActionType
  notes      String
  createdAt  DateTime         @default(now())

  project    Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  reviewer   User             @relation(fields: [reviewerId], references: [id])
}

model Discussion {
  id          String   @id @default(cuid())
  projectId   String?
  title       String
  createdAt   DateTime @default(now())
  createdById String

  project     Project? @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdBy   User     @relation(fields: [createdById], references: [id])
  messages    Message[]
}

model Message {
  id           String     @id @default(cuid())
  discussionId String
  authorId     String
  content      String
  tag          MessageTag?
  createdAt    DateTime   @default(now())

  discussion   Discussion @relation(fields: [discussionId], references: [id], onDelete: Cascade)
  author       User       @relation(fields: [authorId], references: [id])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  title     String
  content   String?
  link      String?
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id])

  @@index([userId, isRead])
}
